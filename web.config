<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- ==================== 核心：URL Rewrite 反向代理规则 ==================== -->
    <rewrite>
      <rules>

        <!--
          规则1：反向代理所有请求到本地 Python 服务
          匹配所有路径，追加查询字符串
        -->
        <rule name="AI-Canvas-ReverseProxy" stopProcessing="true">
          <match url="^(.*)$" />
          <action type="Rewrite" url="http://127.0.0.1:8777/{R:1}" appendQueryString="true" />
        </rule>

      </rules>
    </rewrite>

    <!-- ==================== 代理配置：解决并发连接问题 ==================== -->
    <proxy>
      <!-- 启用 keep-alive 连接复用，减少 TIME_WAIT -->
      <keepAlive enabled="true" />
      <!-- 增加超时时间 -->
      <timeout value="300" />
    </proxy>

    <!-- ==================== 安全与请求限制 ==================== -->
    <security>
      <requestFiltering removeServerHeader="true">
        <!-- 允许上传最大 100MB 文件（图片/视频素材） -->
        <requestLimits maxAllowedContentLength="104857600" maxUrl="4096" maxQueryString="2048" />
        <!-- 允许访问隐藏文件（如 .gitignore 不影响，但防止访问敏感文件） -->
        <hiddenSegments>
          <add segment="venv" />
          <add segment="node_modules" />
          <add segment=".git" />
        </hiddenSegments>
        <fileExtensions allowUnlisted="true">
          <add fileExtension=".py" allowed="false" />
          <add fileExtension=".bat" allowed="false" />
          <add fileExtension=".cmd" allowed="false" />
          <add fileExtension=".ps1" allowed="false" />
          <add fileExtension=".ini" allowed="false" />
          <add fileExtension=".log" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <!-- ==================== HTTP 响应头 ==================== -->
    <httpProtocol>
      <customHeaders>
        <!-- 移除 X-Powered-By 头，减少信息泄露 -->
        <remove name="X-Powered-By" />
        <!-- HSTS：强制浏览器使用 HTTPS（生产环境建议开启） -->
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
        <!-- 防止点击劫持 -->
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <!-- XSS 保护 -->
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

    <!-- ==================== 默认文档（防止目录浏览） ==================== -->
    <defaultDocument enabled="false" />

    <!-- ==================== 目录浏览（必须关闭） ==================== -->
    <directoryBrowse enabled="false" />

  </system.webServer>

  <!-- ==================== ASP.NET 特定配置 ==================== -->
  <system.web>
    <httpRuntime maxRequestLength="102400" executionTimeout="3600" />
    <customErrors mode="Off" />
  </system.web>

</configuration>
